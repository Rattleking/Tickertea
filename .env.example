# Tickertea environment template. Copy to .env and fill in. See docs/architecture/09.

# Database — app connects as the RLS-enforced role; migrations use the admin role.
DATABASE_URL=postgres://tickertea_app:tickertea@localhost:5432/tickertea
DATABASE_ADMIN_URL=postgres://tickertea_admin:tickertea@localhost:5432/tickertea
DB_POOL_MAX=10

# Cache / queue
REDIS_URL=redis://localhost:6379

# S3-compatible object storage (raw payloads + evidence artifacts)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=tickertea-raw
S3_ACCESS_KEY=tickertea
S3_SECRET_KEY=tickertea-secret

# AI providers
CLAUDE_API_KEY=
OPENAI_API_KEY=

# External data sources
DIFFBOT_TOKEN=
