{
  "name": "@tickertea/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Shared API contracts (Zod schemas + inferred types) for Tickertea. Single source of truth for request/response shapes.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "openapi": "tsx openapi.ts > openapi.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
